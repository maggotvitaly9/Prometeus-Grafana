global:
  scrape_interval: 15s

scrape_configs:
  - job_name: "node_exporter"
    scheme: https
    tls_config:
      insecure_skip_verify: true
    basic_auth:
      username: "admin"
      password: "${NODE_EXPORTER_PASSWORD}"
    static_configs:
      - targets: ["node_exporter:9100"]
      
  - job_name: "cadvisor" 
    static_configs:
      - targets: ["cadvisor:8080"]