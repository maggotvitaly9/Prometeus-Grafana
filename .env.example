#!/usr/bin/env dotenv
# @file .env.example
# @brief Шаблон глобальных переменных окружения для стека мониторинга.
# @author Попов В.Д.
# @date 2026-06-07
# @version 1.0.0
# @license GNU GPLv3
#
# @details
# Файл содержит прототипы конфигураций для:
# 1. Авторизации в веб-интерфейсе Grafana
# 2. Безопасного доступа к агенту Node Exporter (Basic Auth)
# 3. Политик хранения временных рядов (TSDB) в Prometheus
# ====================================================================

# НАСТРОЙКИ GRAFANA
# ====================================================================
# ВНИМАНИЕ: Чувствительные данные! Категорически запрещено заполнять 
# реальными паролями в файле, отправляемом в Git-репозиторий.
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=your_secure_grafana_password
# GF_USERS_ALLOW_SIGN_UP=false

# КОНФИГУРАЦИЯ PROMETHEUS
# ====================================================================
# Срок хранения метрик в базе данных (допустимые форматы: 15d, 1y, 30d)
# PROMETHEUS_RETENTION=15d